# KenexAI environment configuration
# Copy this file to `.env` and fill in the values before running the backend.

# Supabase (required for auth + profiles)
SUPABASE_URL=https://your-supabase-url.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-key

# Optional: API keys for auto-generating test questions (priority: OpenRouter first, then Gemini > Grok > OpenAI)
# Open Router (used when set in .env)
OPENROUTER_API_KEY=or-...
OPENROUTER_MODEL=gpt-4o-mini

# Or Gemini (Google AI) - free tier at https://aistudio.google.com/apikey
# GEMINI_API_KEY=...
# GEMINI_MODEL=gemini-2.5-flash

# Or Grok (xAI) / OpenAI (see docs)
